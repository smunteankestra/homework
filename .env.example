# Environment Variables for Autonomy AI Studio E2E Tests
# Copy this file to .env and fill in your test credentials

# ============================================
# REQUIRED: Test account credentials
# ============================================
# Create a test account at: https://studio.autonomyai.io/
TEST_EMAIL=your-test-email@example.com
TEST_PASSWORD=your-test-password

# ============================================
# REQUIRED: Base URL
# ============================================
# The URL of the Autonomy AI Studio app
BASE_URL=https://studio.autonomyai.io

# ============================================
# OPTIONAL: GitHub repo for project initialization tests
# ============================================
# Format: owner/repo (e.g., smunteankestra/jira-clone)
# TEST_REPO_NAME=your-github-username/your-public-repo

# ============================================
# OPTIONAL: GitHub Personal Access Token
# ============================================
# Only needed if you want to automate repo connection in tests
# Get it from: https://github.com/settings/tokens
# GITHUB_TOKEN=your-github-token

# ============================================
# OPTIONAL: Test execution options
# ============================================
# Set to 'true' to run tests in headed mode (see browser)
# HEADLESS=false

# Set to 'true' for detailed debug output
# DEBUG=true

# Test timeout in milliseconds (default: 120000 = 2 minutes)
# TIMEOUT=120000

