# Environment Variables for Autonomy AI Studio E2E Tests
# Copy this file to .env.local and fill in your test credentials

# Required: Test account credentials for studio.autonomyai.io
TEST_EMAIL=your-test-email@example.com
TEST_PASSWORD=your-test-password

# Optional: GitHub repo for project initialization tests
# Format: owner/repo (e.g., smunteankestra/jira-clone)
TEST_REPO_NAME=smunteankestra/jira-clone

# Optional: GitHub Personal Access Token (if needed for repo access)
# GITHUB_TOKEN=your-github-token

# Optional: Override base URL if testing different environment
# APP_URL=http://localhost:3000

# Optional: Test execution options
# DEBUG=true
# HEADLESS=false
# TIMEOUT=60000

